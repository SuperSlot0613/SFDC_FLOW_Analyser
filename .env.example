# =============================================================================
# Salesforce Flow Analyzer - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your credentials
# This file should NOT be committed to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider Configuration (Choose ONE option)
# -----------------------------------------------------------------------------

# ============================================================================
# ⭐ OPTION 1: Custom/Internal LLM (For Company Network)
# ============================================================================
# Use this for any OpenAI-compatible API within your company
# Most internal LLMs follow the OpenAI API format
#
CUSTOM_LLM_API_KEY=your_internal_api_key_here
CUSTOM_LLM_BASE_URL=https://your-internal-llm.company.com/v1
CUSTOM_LLM_MODEL=your-model-name
#
# Example endpoints:
# - Azure ML: https://your-workspace.region.inference.ml.azure.com/score
# - vLLM: http://your-server:8000/v1
# - Ollama: http://localhost:11434/v1
# - LiteLLM: http://your-proxy:4000/v1
# - Custom: https://api.internal.company.com/llm/v1
# ============================================================================

# ============================================================================
# OPTION 2: GitHub Models (FREE with Copilot Pro!)
# ============================================================================
# GITHUB_TOKEN=ghp_your_github_token_here
# GITHUB_MODEL=gpt-4o
# ============================================================================

# ============================================================================
# OPTION 3: OpenAI Direct
# ============================================================================
# OPENAI_API_KEY=sk-your_openai_key_here
# OPENAI_MODEL=gpt-4
# ============================================================================

# ============================================================================
# OPTION 4: Azure OpenAI
# ============================================================================
# AZURE_OPENAI_API_KEY=your_azure_key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name
# AZURE_OPENAI_API_VERSION=2024-02-01
# ============================================================================

# ============================================================================
# OPTION 5: Anthropic Claude
# ============================================================================
# ANTHROPIC_API_KEY=your_anthropic_key
# ANTHROPIC_MODEL=claude-3-sonnet-20240229
# ============================================================================

# -----------------------------------------------------------------------------
# Provider Selection
# -----------------------------------------------------------------------------
# Options: auto, custom, github, openai, azure, anthropic
# 'auto' will auto-detect based on which credentials are set
# Priority: Custom > GitHub > OpenAI > Azure > Anthropic
LLM_PROVIDER=custom

# LLM Settings (applies to all providers)
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4000

# -----------------------------------------------------------------------------
# Salesforce Credentials (Optional - for fetching flows from org)
# -----------------------------------------------------------------------------

# Option A: Direct Access Token (easiest)
# SF_ACCESS_TOKEN=your_session_token
# SF_INSTANCE_URL=https://your-org.my.salesforce.com

# Option B: Connected App OAuth
# SF_CLIENT_ID=your_connected_app_client_id
# SF_CLIENT_SECRET=your_connected_app_secret
# SF_USERNAME=your.email@company.com
# SF_PASSWORD=your_password
# SF_SECURITY_TOKEN=your_security_token
# SF_INSTANCE_URL=https://your-org.my.salesforce.com

SF_API_VERSION=59.0

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
OUTPUT_FORMAT=markdown
ANALYSIS_CACHE_ENABLED=true
ANALYSIS_CACHE_TTL=3600
