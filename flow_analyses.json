            {
              "name": "Is_Lead_Created",
              "label": "Is Lead Created",
              "condition_logic": "and",
              "conditions": [
                {
                  "left": "$Record.isNew__c",
                  "operator": "EqualTo",
                  "right": true
                }
              ]
            },
            {
              "name": "Is_Lead_Closed",
              "label": "Is Lead Closed",
              "condition_logic": "and",
              "conditions": [
                {
                  "left": "$Record.isNew__c",
                  "operator": "EqualTo",
                  "right": false
                }
              ]
            }
          ]
        }
